<view class="container data-v-de8e503d"><view class="header data-v-de8e503d"><text class="title data-v-de8e503d">任务详情</text><text class="date data-v-de8e503d">{{a}}</text></view><view class="task-overview data-v-de8e503d"><view class="overview-card data-v-de8e503d"><view class="task-title data-v-de8e503d">{{b}}</view><view class="task-subtitle data-v-de8e503d">{{c}}</view><view class="task-stats data-v-de8e503d"><view class="stat-item data-v-de8e503d"><text class="stat-value data-v-de8e503d">{{d}}/{{e}}</text><text class="stat-label data-v-de8e503d">动作完成</text></view><view class="stat-item data-v-de8e503d"><text class="stat-value data-v-de8e503d">{{f}}%</text><text class="stat-label data-v-de8e503d">完成进度</text></view><view class="stat-item data-v-de8e503d"><text class="stat-value data-v-de8e503d">{{g}}</text><text class="stat-label data-v-de8e503d">消耗大卡</text></view></view></view></view><view class="exercise-section data-v-de8e503d"><view class="section-title data-v-de8e503d">训练动作</view><view class="exercise-list data-v-de8e503d"><view wx:for="{{h}}" wx:for-item="item" wx:key="l" class="{{['exercise-card', 'data-v-de8e503d', item.m && 'completed', item.n && 'in-progress']}}" bindtap="{{item.o}}"><view class="exercise-info data-v-de8e503d"><view class="exercise-name data-v-de8e503d">{{item.a}}</view><view class="exercise-detail data-v-de8e503d"><text wx:if="{{item.b}}" class="data-v-de8e503d">{{item.c}}组</text><text wx:if="{{item.d}}" class="data-v-de8e503d">×{{item.e}}次</text><text wx:if="{{item.f}}" class="data-v-de8e503d">{{item.g}}秒</text><text wx:if="{{item.h}}" class="rest-time data-v-de8e503d">休息{{item.i}}秒</text></view></view><view class="exercise-status data-v-de8e503d"><text wx:if="{{item.j}}" class="status-icon data-v-de8e503d">✓</text><text wx:elif="{{item.k}}" class="status-icon data-v-de8e503d">▶</text><text wx:else class="status-text data-v-de8e503d">未开始</text></view></view></view></view><view class="footer-actions data-v-de8e503d"><button wx:if="{{i}}" class="action-btn primary data-v-de8e503d" bindtap="{{j}}">开始训练</button><button wx:elif="{{k}}" class="action-btn primary data-v-de8e503d" bindtap="{{l}}">继续训练</button><button wx:elif="{{m}}" class="action-btn success data-v-de8e503d" bindtap="{{n}}">查看总结</button></view></view>