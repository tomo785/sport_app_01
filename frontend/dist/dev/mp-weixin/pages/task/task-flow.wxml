<view class="container data-v-f28beeec"><training-status-card class="data-v-f28beeec" u-i="f28beeec-0" bind:__l="__l"/><view class="calendar-card data-v-f28beeec"><view class="calendar-header data-v-f28beeec"><view class="month-nav data-v-f28beeec" bindtap="{{a}}"><text class="nav-arrow data-v-f28beeec">‹</text></view><text class="month-title data-v-f28beeec">{{b}}年{{c}}月</text><view class="month-nav data-v-f28beeec" bindtap="{{d}}"><text class="nav-arrow data-v-f28beeec">›</text></view></view><view class="week-row data-v-f28beeec"><text wx:for="{{e}}" wx:for-item="w" wx:key="b" class="week-cell data-v-f28beeec">{{w.a}}</text></view><view class="day-grid data-v-f28beeec"><view wx:for="{{f}}" wx:for-item="day" wx:key="c" class="{{['day-cell', 'data-v-f28beeec', day.d && 'other-month', day.e && 'today', day.f && 'selected', day.g && 'has-record']}}" bindtap="{{day.h}}"><text class="day-num data-v-f28beeec">{{day.a}}</text><view wx:if="{{day.b}}" class="day-dot data-v-f28beeec"></view></view></view><view class="calendar-footer data-v-f28beeec"><text wx:if="{{g}}" class="back-today data-v-f28beeec" bindtap="{{h}}">回到今天</text><view class="expand-toggle data-v-f28beeec" bindtap="{{k}}"><text class="expand-text data-v-f28beeec">{{i}}</text><text class="{{['expand-icon', 'data-v-f28beeec', j && 'expanded']}}">▼</text></view></view></view><view class="record-section data-v-f28beeec"><view class="section-header data-v-f28beeec"><text class="section-title data-v-f28beeec">近7天运动</text><text class="more-link data-v-f28beeec" bindtap="{{l}}">查看全部 ›</text></view><view wx:if="{{m}}" class="record-list data-v-f28beeec"><view wx:for="{{n}}" wx:for-item="item" wx:key="j" class="record-item data-v-f28beeec" bindtap="{{item.k}}"><view class="{{['record-icon', 'data-v-f28beeec', item.b]}}"><text class="data-v-f28beeec">{{item.a}}</text></view><view class="record-info data-v-f28beeec"><text class="record-name data-v-f28beeec">{{item.c}}</text><text class="record-time data-v-f28beeec">{{item.d}}</text></view><view class="record-stats data-v-f28beeec"><text class="record-duration data-v-f28beeec">{{item.e}}</text><text wx:if="{{item.f}}" class="record-distance data-v-f28beeec">{{item.g}}</text><text wx:if="{{item.h}}" class="record-calories data-v-f28beeec">{{item.i}}千卡</text></view></view></view><view wx:else class="empty data-v-f28beeec"><text class="data-v-f28beeec">近7天暂无运动记录</text></view></view></view>