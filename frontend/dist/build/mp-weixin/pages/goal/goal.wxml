<view class="container data-v-346c03ed"><view class="header data-v-346c03ed"><view class="header-title data-v-346c03ed">我的目标</view><view class="header-action data-v-346c03ed" bindtap="{{a}}"><text class="icon data-v-346c03ed">+</text><text class="data-v-346c03ed">新建目标</text></view></view><scroll-view class="goal-list data-v-346c03ed" scroll-y><view wx:if="{{b}}" class="section data-v-346c03ed"><view class="section-title data-v-346c03ed"><text class="dot active data-v-346c03ed"></text><text class="data-v-346c03ed">进行中</text></view><view wx:for="{{c}}" wx:for-item="goal" wx:key="g" class="goal-card data-v-346c03ed"><view class="goal-header data-v-346c03ed"><view class="goal-type data-v-346c03ed">{{goal.a}}</view><view class="goal-status active data-v-346c03ed">进行中</view></view><view class="goal-content data-v-346c03ed"><view class="goal-value data-v-346c03ed">{{goal.b}}{{goal.c}}</view><view class="goal-date data-v-346c03ed">{{goal.d}} 开始</view></view><view class="goal-actions data-v-346c03ed"><button class="btn-complete data-v-346c03ed" bindtap="{{goal.e}}">完成</button><button class="btn-delete data-v-346c03ed" bindtap="{{goal.f}}">删除</button></view></view></view><view wx:if="{{d}}" class="section data-v-346c03ed"><view class="section-title data-v-346c03ed"><text class="dot completed data-v-346c03ed"></text><text class="data-v-346c03ed">已完成</text></view><view wx:for="{{e}}" wx:for-item="goal" wx:key="e" class="goal-card completed data-v-346c03ed"><view class="goal-header data-v-346c03ed"><view class="goal-type data-v-346c03ed">{{goal.a}}</view><view class="goal-status completed data-v-346c03ed">已完成</view></view><view class="goal-content data-v-346c03ed"><view class="goal-value data-v-346c03ed">{{goal.b}}{{goal.c}}</view><view class="goal-date data-v-346c03ed">{{goal.d}} 开始</view></view></view></view><view wx:if="{{f}}" class="empty data-v-346c03ed"><text class="empty-text data-v-346c03ed">暂无目标，点击右上角创建</text></view></scroll-view><view wx:if="{{g}}" class="modal data-v-346c03ed" bindtap="{{w}}"><view class="modal-content data-v-346c03ed" catchtap="{{v}}"><view class="modal-header data-v-346c03ed"><text class="modal-title data-v-346c03ed">新建目标</text><text class="modal-close data-v-346c03ed" bindtap="{{h}}">×</text></view><view class="modal-body data-v-346c03ed"><view class="form-item data-v-346c03ed"><text class="form-label data-v-346c03ed">目标类型</text><picker class="data-v-346c03ed" mode="selector" range="{{j}}" value="{{k}}" bindchange="{{l}}"><view class="picker data-v-346c03ed">{{i}}</view></picker></view><view class="form-item data-v-346c03ed"><text class="form-label data-v-346c03ed">目标值</text><input class="input data-v-346c03ed" type="number" placeholder="{{m}}" value="{{n}}" bindinput="{{o}}"/></view><view class="form-item data-v-346c03ed"><text class="form-label data-v-346c03ed">开始日期</text><picker class="data-v-346c03ed" mode="date" value="{{q}}" bindchange="{{r}}"><view class="picker data-v-346c03ed">{{p}}</view></picker></view></view><view class="modal-footer data-v-346c03ed"><button class="btn-cancel data-v-346c03ed" bindtap="{{s}}">取消</button><button class="btn-confirm data-v-346c03ed" bindtap="{{t}}">确定</button></view></view></view></view>