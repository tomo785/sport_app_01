<view class="container data-v-0a189fc4"><view class="header data-v-0a189fc4"><text class="title data-v-0a189fc4">任务详情</text><text class="date data-v-0a189fc4">{{a}}</text></view><view class="task-overview data-v-0a189fc4"><view class="overview-card data-v-0a189fc4"><view class="task-title data-v-0a189fc4">{{b}}</view><view class="task-subtitle data-v-0a189fc4">{{c}}</view><view class="task-stats data-v-0a189fc4"><view class="stat-item data-v-0a189fc4"><text class="stat-value data-v-0a189fc4">{{d}}/{{e}}</text><text class="stat-label data-v-0a189fc4">动作完成</text></view><view class="stat-item data-v-0a189fc4"><text class="stat-value data-v-0a189fc4">{{f}}%</text><text class="stat-label data-v-0a189fc4">完成进度</text></view><view class="stat-item data-v-0a189fc4"><text class="stat-value data-v-0a189fc4">{{g}}</text><text class="stat-label data-v-0a189fc4">消耗大卡</text></view></view></view></view><view class="exercise-section data-v-0a189fc4"><view class="section-title data-v-0a189fc4">训练动作</view><view class="exercise-list data-v-0a189fc4"><view wx:for="{{h}}" wx:for-item="item" wx:key="l" class="{{['exercise-card', 'data-v-0a189fc4', item.m && 'completed', item.n && 'in-progress']}}" bindtap="{{item.o}}"><view class="exercise-info data-v-0a189fc4"><view class="exercise-name data-v-0a189fc4">{{item.a}}</view><view class="exercise-detail data-v-0a189fc4"><text wx:if="{{item.b}}" class="data-v-0a189fc4">{{item.c}}组</text><text wx:if="{{item.d}}" class="data-v-0a189fc4">×{{item.e}}次</text><text wx:if="{{item.f}}" class="data-v-0a189fc4">{{item.g}}秒</text><text wx:if="{{item.h}}" class="rest-time data-v-0a189fc4">休息{{item.i}}秒</text></view></view><view class="exercise-status data-v-0a189fc4"><text wx:if="{{item.j}}" class="status-icon data-v-0a189fc4">✓</text><text wx:elif="{{item.k}}" class="status-icon data-v-0a189fc4">▶</text><text wx:else class="status-text data-v-0a189fc4">未开始</text></view></view></view></view><view class="footer-actions data-v-0a189fc4"><button wx:if="{{i}}" class="action-btn primary data-v-0a189fc4" bindtap="{{j}}">开始训练</button><button wx:elif="{{k}}" class="action-btn primary data-v-0a189fc4" bindtap="{{l}}">继续训练</button><button wx:elif="{{m}}" class="action-btn success data-v-0a189fc4" bindtap="{{n}}">查看总结</button></view></view>