.container{min-height:100vh;background-color:#f5f5f5}.card{background:#fff;border-radius:20rpx;padding:30rpx;box-shadow:0 4rpx 20rpx rgba(0,0,0,.05)}.btn-primary{background:linear-gradient(135deg,#4caf50,#45a049);color:#fff;border:none;border-radius:10rpx}.btn-primary[disabled]{opacity:.6}.btn-default{background:#f5f5f5;color:#4caf50;border:none;border-radius:10rpx}.empty-state{display:flex;flex-direction:column;align-items:center;padding:60rpx 0}.empty-state .empty-icon{width:120rpx;height:120rpx;margin-bottom:20rpx}.empty-state .empty-text{font-size:28rpx;color:#999}.divider{position:relative;text-align:center;margin:30rpx 0}.divider:before,.divider:after{content:"";position:absolute;top:50%;width:30%;height:1rpx;background:#e5e5e5}.divider:before{left:0}.divider:after{right:0}.divider .divider-text{font-size:24rpx;color:#999}page{background-color:#f5f5f5;font-size:28rpx;color:#333}view,text,image,input,button,scroll-view{box-sizing:border-box}button:after{border:none}.safe-area-bottom{padding-bottom:constant(safe-area-inset-bottom);padding-bottom:env(safe-area-inset-bottom)}
page{--status-bar-height:25px;--top-window-height:0px;--window-top:0px;--window-bottom:0px;--window-left:0px;--window-right:0px;--window-magin:0px}[data-c-h="true"]{display: none !important;}